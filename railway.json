{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "streamlit run app.py --server.port $PORT --server.headless true --server.address 0.0.0.0 --browser.gatherUsageStats false",
    "healthcheckPath": "/_stcore/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
